rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserDoc() {
      // Used to avoid multiple gets
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function getRole() {
      return getUserDoc().role;
    }
    
    function getTenantId() {
      return getUserDoc().tenantId;
    }

    function getLinkedClientId() {
      return getUserDoc().linkedClientId;
    }

    // --- Rules ---

    // 1. Users Collection
    match /users/{userId} {
      // User can read their own profile, or anyone in the same tenant
      allow read: if isAuthenticated() && (request.auth.uid == userId || resource.data.tenantId == getTenantId());
      // Users can create their own document on signup
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if false; // Protect users from arbitrary deletion
    }

    // 2. Cases Collection (Strict isolation + Client Portal logic)
    match /cases/{docId} {
      // Lawyers see all cases in tenant. Clients see only cases matching their linkedClientId.
      allow read: if isAuthenticated() && 
                  resource.data.tenantId == getTenantId() && 
                  (getRole() != 'client' || resource.data.clientId == getLinkedClientId());
      
      // Only non-clients can modify cases
      allow update, delete: if isAuthenticated() && 
                            resource.data.tenantId == getTenantId() && 
                            getRole() != 'client';
                            
      // Only non-clients can create cases, must enforce tenantId matches their own
      allow create: if isAuthenticated() && 
                    request.resource.data.tenantId == getTenantId() && 
                    getRole() != 'client';
    }

    // 3. Global Multi-Tenant Fallback (Invoices, Clients, Tasks, etc.)
    match /{path=**}/documents/{docId} {
      // For any collection not explicitly matched above, isolate by tenantId
      allow read: if isAuthenticated() && resource.data.tenantId == getTenantId() && getRole() != 'client';
      allow update, delete: if isAuthenticated() && resource.data.tenantId == getTenantId() && getRole() != 'client';
      allow create: if isAuthenticated() && request.resource.data.tenantId == getTenantId() && getRole() != 'client';
    }
  }
}
