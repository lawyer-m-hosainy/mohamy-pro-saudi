rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function currentTenantId() {
      return request.auth.token.tenant_id != null
        ? request.auth.token.tenant_id
        : 'demo-tenant';
    }

    function isStaffOrLawyer() {
      return isAuthenticated() &&
        (
          request.auth.token.role in ['admin', 'office_admin', 'lawyer', 'partner', 'consultant', 'trainee_lawyer', 'staff', 'secretary'] ||
          request.auth.token.demo_admin == true
        );
    }

    // tenant-scoped case documents:
    // tenants/{tenantId}/cases/{caseId}/{fileName}
    match /tenants/{tenantId}/cases/{caseId}/{fileName} {
      allow read: if isStaffOrLawyer() && tenantId == currentTenantId();
      allow write: if isStaffOrLawyer() &&
                   tenantId == currentTenantId() &&
                   request.resource.size < 10 * 1024 * 1024 &&
                   request.resource.contentType.matches('application/pdf|application/msword|application/vnd.openxmlformats-officedocument.wordprocessingml.document|text/plain');
    }
  }
}
