{
  "name": "malaf-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "build:server": "tsc server.ts --esModuleInterop --target ES2022 --module NodeNext --moduleResolution NodeNext",
    "build:all": "npm run build && npm run build:server",
    "start": "node server.js",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "demo:seed": "tsx scripts/demo-seed.ts",
    "demo:reset": "tsx scripts/demo-reset.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
